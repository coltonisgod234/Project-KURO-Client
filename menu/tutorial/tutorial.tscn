[node name="characters 3 activation" type="Node" parent="." node_paths=PackedStringArray("default_button")]
script = ExtResource("3_yjt82")
rich_text = "To [as]activate[/as] an [as]ability[/as],
first hold down (or press) [as]spacebar[/as].
then, press the key corresponding to your [as]character[/as]:
- [as]Key 1[/as] for the first [as]character[/as]
- [as]Key 2[/as] for the second
- [as]Key 3[/as] for the third
- [as]Key 4[/as] for the fourth

then, press the key corresponding to your [as]ability[/as]:
- [as]Key 1[/as] for the [as]primary ability[/as]
- [as]Key 2[/as] for the 1st [as]secondary ability[/as]
- [as]Key 3[/as] for the 2nd [as]secondary ability[/as]
- [as]Key 4[/as] for the 3rd [as]secondary ability[/as]
"
character_name = "Asahi"
default_button = NodePath("../defbtn")
metadata/_custom_type_script = "uid://dtkvtfngw82l5"

[node name="characters 3 tips" type="Node" parent="." node_paths=PackedStringArray("default_button")]
